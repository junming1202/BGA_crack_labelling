# ── Secrets ──────────────────────────────────────────────────────────────────
.env

# ── Project data (large binary files) ────────────────────────────────────────
database/

# ── Python virtual environment (uv) ──────────────────────────────────────────
.venv/

# ── uv lock file is intentionally tracked (reproducible installs)
# uv.lock  ← do NOT ignore

# ── Python cache & compiled files ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd

# ── Jupyter notebook artefacts ────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Build / distribution artefacts ───────────────────────────────────────────
dist/
build/
*.egg-info/

# ── Output spreadsheets generated by the tool ────────────────────────────────
# (kept out of version control; re-generate from notebooks)
**/output/*_BGA_label_output.xlsx

# ── Generated validation artefacts (re-generate from notebook 02) ────────────
**/output/overlays/

# ── OS artefacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
